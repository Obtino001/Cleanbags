{% if section.blocks.size > 0 %}
  
<style>
  /******************************* COMPARISON TABLE SECTION CSS ********************************/
.comparison-table-section{ padding-top: {{section.settings.padding_top}}px; padding-bottom: {{section.settings.padding_bottom}}px; }
.comparison-table-section .page-width{ max-width: 900px; }
.comparison-table-section .table-container .row {
