{% assign review_limit = section.settings.limit_reviews %}
{% assign reviews = shop.metaobjects.trustpilot_reviews.values  %}

{%- if reviews.count > 0 -%}
{%- style -%}
  .testimonials-{{ section.id }} {
    background-color: {{ section.settings.color_background }};
    color: {{ section.settings.color_text }};
  }

  {%- assign padding_bottom_mobile = section.settings.padding_bottom_mobile -%}
  {%- if padding_bottom_mobile == 0 -%}
    {%- assign padding_bottom_mobile = section.settings.padding_bottom -%}
  {%- endif -%}

  {%- assign padding_top_mobile = section.settings.padding_top_mobile -%}
  {%- if padding_top_mobile == 0 -%}
    {%- assign padding_top_mobile = section.settings.padding_top -%}
  {%- endif -%}

  .section-{{ section.id }} {
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .trustpilot--section-testimonials {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}
  .trustpilot--section-testimonials .section-header {
    width: 30%;
}
  .trustpilot--section-testimonials .slideshow-wrapper {
    width: calc(70% - 10px);
}

  .trustpilot--section-testimonials .section-header image-element img.tp_star_image {
    max-width: 140px;
    margin: 0 auto;
}
  .trustpilot--section-testimonials .section-header .tp_text {
    padding: 10px 0;
    font-size: 12px;
}
.trustpilot--section-testimonials .section-header a image-element img.tp_logo_image {
    max-width: 140px;
    margin: 0 auto;
}
  /* .trustpilot--section-testimonials .section-header .trustpilot-testimonials-content {
    max-width: 700px;
    margin-left: auto;
    padding-left: 60px;
} */

    .trustpilot--section-testimonials .section-header .trustpilot-testimonials-content {
    max-width: 420px;
    margin-left: auto;
    padding-left: 60px;
}

  /* .trustpilot--section-testimonials .slideshow-wrapper .trustpilot--section-slideshow {
    max-width: 1750px;
    width: 100%;
    margin-left: auto;
} */
   .trustpilot--section-testimonials .slideshow-wrapper .trustpilot--section-slideshow {
    max-width: auto;
    width: 100%;
    margin-left: auto;
}

 .trustpilot--section-testimonials .testimonials-slide.is-selected .testimonials-slider__text {
    transform: none;
   box-shadow: none;
}
  .trustpilot--section-testimonials .testimonials-slide .testimonials-slider__text {
    transform: none;
    transition: none;
    margin-left: 18px;
    text-align: left;
    border: 1px solid #E4E4E4;
}

  .trustpilot--section-testimonials .testimonials-slide {
    width: 42%;
}


 .trustpilot--section-testimonials .flickity-previous {
    left: -250px;
    top: 290px;
}
 .trustpilot--section-testimonials .flickity-next {
    left: -190px;
    top: 290px;
}

  .trustpilot--section-testimonials .flickity-button {
    background: transparent;
    border: none;
    border-radius: 50%;
    color: #000;
    position: absolute;
    border: 1px solid #D0D0D0;
}
   .rating span.rating-star {
    position: relative;
}
