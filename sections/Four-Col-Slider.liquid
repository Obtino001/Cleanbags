{% assign image_limit = section.settings.limit_images %}
{% assign images = section.blocks %}
{% style %}
  .image-slider--section-wrapper {
    display: flex;
    justify-content: center;
    background-color: {{ section.settings.color_background }};
  }

  .layout-four-column-slider {
    max-width: 1200px;
    width: 100%;
  }

  .image-slide {
    border-radius: 12px;
    width: calc(25% - 22.5px); /* Adjust for gap */
    margin-right: 30px;
  }

  /*.image-slide:last-child {
    margin-right: 0;
  }*/

  .slide-image-el {
    text-align: center;
  }

  .slide-image {
    width: 100%;
    max-width: 100%;
    border-radius: 10px;
    object-fit: cover;
  }
  .section-{{ section.id }} .flickity-page-dots .dot{
    height: 3px;
    margin: 0 5px;
    width: 50px;
    border-color: rgb(189 184 184);
    border-radius: 0px;
  }
  .section-{{ section.id }} .flickity-page-dots{
    bottom: -65px;
  }
  .section-{{section.id}} .flickity-page-dots .dot.is-selected{
    border-color: #000;
  }
  .section-{{ section.id }} .flickity-prev-next-button{
    background: transparent;
    border: none;
    border-radius: 50%;
    color: #000;
    position: absolute;
    border: 1px solid #D0D0D0;
  }
  
  /* MOBILE */
  @media screen and (max-width: 768px) {
    .image-slide {
      width: calc(50% - 15px); /* Two columns on mobile */
      margin-right: 30px;
    }

    .image-slide:nth-child(even) {
      margin-right: 0;
    }
    
    .section-{{ section.id }} .flickity-page-dots{
      bottom: -35px;
    }
  }

  @media screen and (max-width: 480px) {
    .image-slide {
      width: 100%; /* Single column on smaller mobiles */
      margin-right: 0;
    }
  }
  {%- assign padding_bottom_mobile = section.settings.padding_bottom_mobile -%}
  {%- if padding_bottom_mobile == 0 -%}
    {%- assign padding_bottom_mobile = section.settings.padding_bottom -%}
  {%- endif -%}

  {%- assign padding_top_mobile = section.settings.padding_top_mobile -%}
  {%- if padding_top_mobile == 0 -%}
    {%- assign padding_top_mobile = section.settings.padding_top -%}
  {%- endif -%}

  .section-{{ section.id }} {
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    .section-{{ section.id }} .flickity-next {
        right: -70px;
    }
    .section-{{ section.id }} .flickity-previous {
        left: -70px;
    }
  }

{% endstyle %}
<div class="section-{{ section.id }}"  style="background-color: {{ section.settings.color_background}}">
{% if section.settings.title != blank %}
  <div class="section-header text-center">
        <h2>{{ section.settings.title | escape }}</h2>
  </div>
      {% endif %}
<div class="image-slider--section-wrapper">
  
  <div class="image-slider layout-four-column-slider">
    <div class="review-slider" data-flickity='{
      "cellAlign": "left",
      "contain": true,
      "wrapAround": true,
      "groupCells": 1,
      "pageDots": true,
      "prevNextButtons": true,
      "imagesLoaded": true 
    }'>
      {% for block in section.blocks %}
        <div
          class="image-slide slide video-slide--{{ block.id }} image-slide--{{ block.id }}"
          {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="slide-image-el">
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="slide-image">
            </div>
          {% elsif block.settings.video != blank and block.settings.cover_image != blank %}
            <div class="video-container">
              <div class="video-cover" data-video-id="{{ block.id }}">
                <img
                  src="{{ block.settings.cover_image | image_url: width: 400 }}"
                  alt="Video Cover"
                  class="cover-image">
                <div class="play-icon">
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          {% endif %}
        <div class="video-popup" id="video-popup-{{ block.id }}">
                <div class="video-popup-inner">
                  <button class="close-popup">&times;</button>
                  {{ block.settings.video | video_tag:
                    autoplay: false,
                    loop: block.settings.loop,
                    muted: false,
                    controls: true,
                    class: 'popup-video'
                  }}
                </div>
              </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
</div>
{% schema %}
{
