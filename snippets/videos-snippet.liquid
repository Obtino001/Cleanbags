<script>
  const popup = document.querySelector('.video-popup');
  if (popup && popup.parentElement !== document.body) {
    document.body.appendChild(popup);
  }

  document.addEventListener("DOMContentLoaded", function () {
    let globalMuted = false;
    let progressBars = [];
    let animationFrameId;

    // --- Main Swiper Initialization ---
    const mainSwiper = new Swiper(".swiper-main-video", {
      slidesPerView: 1,
      loop: true,
      direction: "horizontal", // Horizontal swipe feels more natural for stories
      speed: 400,
    });

    // --- Initialize Progress UI ---
    function initProgressBars() {
      const container = document.getElementById('storyProgressContainer');
      if (!container) return;
      container.innerHTML = '';
      progressBars = [];
      const totalSlides = document.querySelectorAll('.swiper-main-video .swiper-slide:not(.swiper-slide-duplicate)').length;
      
      for (let i = 0; i < totalSlides; i++) {
        const bar = document.createElement('div');
        bar.className = 'story-progress-bar';
        const fill = document.createElement('div');
        fill.className = 'story-progress-fill';
        bar.appendChild(fill);
        container.appendChild(bar);
        progressBars.push(fill);
      }
    }

    // --- Smooth Animation loop for Progress bars ---
    function updateProgressLoop() {
      const activeVideo = document.querySelector('.swiper-main-video .swiper-slide-active video');
      if (activeVideo && !activeVideo.paused && activeVideo.duration) {
        const pct = (activeVideo.currentTime / activeVideo.duration) * 100;
        const activeIdx = mainSwiper.realIndex;
        if(progressBars[activeIdx]) {
           progressBars[activeIdx].style.width = `${pct}%`;
        }
      }
      animationFrameId = requestAnimationFrame(updateProgressLoop);
    }

    // --- Bind Video Actions & Controls ---
    function bindVideoControls() {
      document.querySelectorAll('.swiper-main-video .swiper-slide').forEach(slide => {
        const video = slide.querySelector('video');
        const btn = slide.querySelector('.speaker-btn');
        const overlay = slide.querySelector('.pause-overlay');
        if (!video || !btn || !overlay) return;

        // Auto Advance to Next Slide
        video.removeAttribute('loop'); 
        video.addEventListener('ended', () => {
          if (video.closest('.swiper-slide-active')) {
             mainSwiper.slideNext();
          }
        });

        // Click to Pause / Play
        const togglePlay = () => {
          if (video.paused) video.play().catch(console.warn);
          else video.pause();
        };
        video.addEventListener('click', togglePlay);
        overlay.addEventListener('click', togglePlay);

        video.addEventListener('pause', () => overlay.classList.add('show-overlay'));
        video.addEventListener('play', () => overlay.classList.remove('show-overlay'));

        // Toggle Sound State
        btn.addEventListener('click', e => {
          e.preventDefault();
          e.stopPropagation();
          globalMuted = !globalMuted;
          applyMuteState();
        });
      });
    }

    function applyMuteState() {
       document.querySelectorAll('.swiper-main-video .swiper-slide video').forEach(v => v.muted = globalMuted);
       document.querySelectorAll('.swiper-main-video .speaker-btn').forEach(b => b.classList.toggle('unmuted', !globalMuted));
    }

    // --- Synchronization & Active Logic ---
    function syncSlideVideos() {
      const realIdx = mainSwiper.realIndex;
      
      // Reset progress bars completely
      progressBars.forEach((fill, idx) => {
        if (idx > realIdx) fill.style.width = '0%';
        if (idx < realIdx) fill.style.width = '100%';
      });

      const activeVideo = document.querySelector('.swiper-main-video .swiper-slide-active video');
      
      document.querySelectorAll(".swiper-main-video .swiper-slide video").forEach((video) => {
        if (video === activeVideo) {
          video.currentTime = 0;
          video.muted = globalMuted;
          video.play().catch(() => {});
        } else {
          video.pause();
          video.currentTime = 0;
        }
      });
    }

    // --- Core Listeners ---
    mainSwiper.on("slideChange", syncSlideVideos);

    window.toggleVideoPopup = function (show) {
      const modal = document.getElementById("videoModal");
      if (!modal) return;
      modal.classList.toggle("active", !!show);

      if (show) {
        requestAnimationFrame(updateProgressLoop);
      } else {
        cancelAnimationFrame(animationFrameId);
        document.querySelectorAll(".swiper-main-video .swiper-slide video").forEach(v => {
          v.pause();
          v.currentTime = 0;
        });
      }
    };

    document.getElementById("storyCloseBtn")?.addEventListener("click", () => toggleVideoPopup(false));

    // Open Popup from Thumbnails
    document.querySelectorAll(".video-thumbnails video").forEach((vid, idx) => {
      vid.addEventListener("click", () => {
        toggleVideoPopup(true);
        mainSwiper.slideToLoop(idx, 0); // Jump instantly to slide without transition
        syncSlideVideos();
      });
    });

    // Boot Everything up
    initProgressBars();
    bindVideoControls();
    mainSwiper.init(); 
  });
</script>