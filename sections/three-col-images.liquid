{% style %}
  .three-step-wrapper {
    background-color: {{ section.settings.background_color }};
  }

  {%- assign padding_bottom_mobile = section.settings.padding_bottom_mobile -%}
  {%- if padding_bottom_mobile == 0 -%}
    {%- assign padding_bottom_mobile = section.settings.padding_bottom -%}
  {%- endif -%}

  {%- assign padding_top_mobile = section.settings.padding_top_mobile -%}
  {%- if padding_top_mobile == 0 -%}
    {%- assign padding_top_mobile = section.settings.padding_top -%}
  {%- endif -%}

  .section-{{ section.id }} {
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
    
    background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
    /* You might want to add other background properties like: */
    background-size: cover; /* Or contain, auto, etc. */
    background-repeat: no-repeat; /* Or repeat, repeat-x, repeat-y */
    background-position: center center; /* Or top, bottom, left, right, percentages */
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .three-step-grid{
    display: flex;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.column_gap }}px;
  }

  .step-image-wrapper {
    margin-bottom: 15px;
  }

  .step-image {
    max-width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px; /* Optional: for rounded image corners */
  }

  .step-title {
    margin-bottom: 10px;
    font-weight: bold;
    color: {{ block.settings.title_color }};
  }

  .step-text {
    color: {{ block.settings.text_color }};
    font-size: 0.9em;
  }
  .watchBtn{
    margin-top: 50px;
  }
  @media screen and (max-width: 768px) {
    .three-step-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      flex-direction: column;
    }
  }
{% endstyle %}

<div class="index-sectionss three-step-wrapper section-{{ section.id }}">
  {% if section.settings.title != blank %}
  <div class="section-header text-center">
        <h2>{{ section.settings.title | escape }}</h2>
        {% if section.settings.subtitle != blank %}
        <p class="text-center">{{ section.settings.subtitle | escape }}</p>
        {% endif %}
  </div>
  {% endif %}
  <div class="page-width three-step-grid">
    {% for block in section.blocks %}
      {% style %}
        .step-item {
    background-color: {{ block.settings.column_background }};
    padding: {{ block.settings.column_padding }}px;
    text-align: left; /* Center align content like in the image */
    border-radius: {{ block.settings.column_border_radius }}px; /* Optional: for rounded corners */
          
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-grow: 1;

  }
  .three-step-item {
    flex: 1 1 calc(33.333% - 20px); /* 3 items per row with gap */
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: 100%;
  }

        .three-steps-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 20px; /* optional space between steps */
}


  .step-number {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 60px; /* Adjust as needed */
    height: 60px; /* Adjust as needed */
    border-radius: 50%;
    background-color: {{ block.settings.number_background_color }};
    color: {{ block.settings.number_text_color }};
    margin-bottom: 15px;
    font-weight: bold;
    margin-left: auto;
    margin-right: auto;
  }
        
        {% endstyle %}
        
        <div class="three-step-item" {{ block.shopify_attributes }}>
        {% if block.settings.step_number != blank %}
          <div class="step-number">{{ block.settings.step_number }}</div>
        {% endif %}
        <div class="step-item">
          {% if block.settings.image != blank %}
            <div class="step-image-wrapper">
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image.alt | escape }}"
                class="step-image"
                loading="lazy"
              >
            </div>
          {% endif %}
          {% if block.settings.sub_text != blank %}
            <p class="step-text">{{ block.settings.sub_text }}</p>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="step-text">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  {%- if section.settings.button_label != blank -%}
          <div class="appear-delay{% cycle '','-1','-2','-3','-4' %} text-center watchBtn">
            <a href="{{ section.settings.button_link }}" class="btn{% if section.settings.button_style == 'secondary' %} btn--tertiary{% endif %}">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
</div>

{% schema %}
{
  "name": "Three Step Process",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.text-and-image.settings.title.label",
      "default": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.text-and-image.settings.subtitle.label",
