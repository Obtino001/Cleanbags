<style>
  /* --- Original Base Styles --- */
  .video-thumbnails .swiper-slide video{width:100%;height:auto;object-fit:cover;border:2px solid transparent;cursor:pointer;}
  .swiper-wrapper-md{padding-block:10px;display:flex;align-items:start;gap:10px;margin-top:var(--video-margin-top,20px);margin-bottom:var(--video-margin-bottom,20px);flex-wrap:nowrap;overflow-x:scroll !important;overflow-y:hidden;-webkit-overflow-scrolling:touch;scroll-behavior:smooth;transform:translate3d(0,0,0);right:-100%;scrollbar-width:none;}
  .preview-title-story{font-size:12px;line-height:16px;max-width:128px !important;font-weight:400;text-align:center;word-wrap:break-word;}
  
  /* Modal Overrides for 1-to-1 Story UI */
  .video-popup {
    position:fixed;
    inset:0;
    z-index:20000;
    display:none;
    justify-content:center;
    align-items:center;
    background:rgba(0,0,0,0.8);
    backdrop-filter:blur(15px);
    -webkit-backdrop-filter:blur(15px);
    width:100%;
    height:100%;
  }
  .video-popup.active { display:flex !important; }
  body:has(.video-popup.active){overflow:hidden;height:100vh;position:fixed;width:100%;}
  body:has(.video-popup.active) header{display:none !important;}
  body:has(.video-popup.active) .MA-announcement-container{display:none !important;}
  body:has(.video-popup.active) .MA-swiper-header{display:none !important;}
  
  /* Centered Vertical Story Box */
  .video-popup .main-video {
    width: 100%;
    max-width: 420px; 
    height: 85vh; 
    aspect-ratio: 9/16;
    position: relative; 
    margin: auto; 
    padding: 0; 
  }
  .video-popup .swiper-main-video { 
    border-radius: 12px; 
    overflow: hidden; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  video.mainPopupVideoEl { 
    height: 100%; 
    width: 100%; 
    object-fit: cover; 
    border-radius: 12px;
  }
  
  /* Hide unnecessary elements from old layout */
  .thumbnail-strip { display: none !important; } 
  #closeVideoModal { display: none !important; }

  /* New Story UI Elements */
  .story-close-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(5px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 200001;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .story-close-btn:hover {
    background: rgba(0,0,0,0.7);
  }
  .story-progress-container {
    position: absolute;
    top: 15px;
    left: 15px;
    right: 55px; /* Leaves space for close button */
    display: flex;
    gap: 4px;
    z-index: 200001;
  }
  .story-progress-bar {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
    overflow: hidden;
  }
  .story-progress-fill {
    height: 100%;
    background: #fff;
    width: 0%;
    /* Removed CSS transition; JS handles smooth animation via requestAnimationFrame */
  }

  /* Play/Pause & Speaker Elements */
  .swiper-main-video button{position:absolute;top:60px;right:7px;background-color:transparent;border:1px solid transparent;border-radius:50%;cursor:pointer;display:flex;height:48px;justify-content:center;width:48px;z-index:9999;}
  .swiper-main-video .speaker-btn .mute-btn{display:none;}
  .swiper-main-video .speaker-btn.unmuted .unmute-btn{display:none;}
  .swiper-main-video .speaker-btn.unmuted .mute-btn{display:inline-block;}
  .swiper-main-video .pause-overlay{position:absolute;top:0;left:0;width:100%;height:100%;display:none;align-items:center;justify-content:center;cursor:pointer;background:rgba(0,0,0,0.3);}
  .swiper-main-video .pause-overlay svg{width:74px;height:74px;}
  .swiper-main-video .pause-overlay.show-overlay{display:flex;}

  @media screen and (max-width:1024px){
    .video-popup .main-video{max-width:100%; height: 100vh; padding: 0; border-radius: 0;}
    .video-popup .swiper-main-video { border-radius: 0; }
    video.mainPopupVideoEl { border-radius: 0; }
  }

  /* --- Grid Thumbs Styling --- */
  .headingCustom {
    text-align: left;
    font-size: 24px;
    font-weight: 500;
    color: #2E4643;
    margin-bottom: 20px;
  }
  .swiper-slide-md {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    position: relative; 
    width: 140px; 
    height: 215px; 
    border: 2px solid #2E4643; 
    border-radius: 10px;
    padding: 3px;
    background: #fff;
    transition: transform 0.2s ease-in-out;
  }
  .swiper-slide-md video {
    width: 100% !important;
    height: 100% !important;
    margin: 0;
    border-radius: 6px; 
    object-fit: cover;
    pointer-events: none;
  }
  .swiper-slide-md:hover { transform: scale(1.02); }
  @media screen and (max-width: 768px) {
    .swiper-wrapper-md { justify-content: flex-start; }
  }
</style>

<div class="video-thumbnails-container">
  <div class="headingCustom">
    {{ block.settings.Heading }}
  </div>
  <div class="video-thumbnails" style="--video-margin-top: {{ block.settings.video_margin_top }}px; --video-margin-bottom: {{ block.settings.video_margin_bottom }}px;">
    <div class="swiper-thumbs">
      <div class="swiper-wrapper-md">
        {% if block.settings.use_metafields %}
          {% assign video_sources = product.metafields.custom.video_thumbnails.value %}
          {% for video in video_sources %}
            <div class="swiper-slide-md">
              {{ video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'desktop-video-md', loading: lazy }}
            </div>
          {% endfor %}
        {% else %}
          {%- for i in (1..5) -%}
            {%- capture video_key -%}video_{{ i }}{%- endcapture -%}
            {%- assign video_file = block.settings[video_key] -%}
            {%- if video_file != blank -%}
              <div class="swiper-slide-md">
                {{ video_file | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'desktop-video-md', loading: lazy }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {% endif %}
      </div>
    </div>
  </div>

