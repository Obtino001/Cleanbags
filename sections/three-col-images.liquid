          "label": "Step Number",
          "default": "1"
        },
        {
          "type": "color",
          "id": "number_background_color",
          "label": "Number Background Color",
          "default": "#1e70bf"
        },
        {
          "type": "color",
          "id": "number_text_color",
          "label": "Number Text Color",
          "default": "#ffffff"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_border_radius",
          "label": "Image Border Radius",
          "unit": "px",
          "min": 0,
          "max": 20,
          "step": 2,
          "default": 2
        },
        {
          "type": "text",
          "id": "sub_text",
          "label": "Sub Title"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "color",
          "id": "column_background",
          "label": "Column Background Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "column_padding",
          "label": "Column Padding",
          "unit": "px",
          "min": 0,
          "max": 50,
          "step": 5,
          "default": 20
        },
        {
          "type": "range",
          "id": "column_border_radius",
          "label": "Column Border Radius",
          "unit": "px",
          "min": 0,
          "max": 20,
          "step": 2,
          "default": 4
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Step Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "1",
            "sub_text": "<p>Description for step one.</p>",
            "title": "Step One Title",
            "text": "<p>Description for step one.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "2",
            "sub_text": "<p>Description for step one.</p>",
            "title": "Step Two Title",
            "text": "<p>Description for step two.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "3",
            "sub_text": "<p>Description for step one.</p>",
            "title": "Step Three Title",
            "text": "<p>Description for step three.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}