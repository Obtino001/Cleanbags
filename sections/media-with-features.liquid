{% style %}
  .{{ section.id }} .section-header{ max-width: 600px; margin-left: auto; margin-right: auto; }
  .{{ section.id }} .btn{ float: none; }
  .{{ section.id }} .sec-content{ display: flex; gap: 50px; align-items: center; flex-wrap: wrap; }
  .{{ section.id }} .feature-image{ width: 60%; border-radius: 24px; overflow: hidden; }
  .{{ section.id }} .feature-image video{ width: 100%; display: block; }
  .{{ section.id }} .feature-blocks{ width: calc(40% - 51px); background: #B2CFFC29; border-radius: 12px; padding: 20px 30px; }
  .{{ section.id }} .feature-blocks .feature-block{ 
    width: 100%;
    display: flex;
    align-items: center;
    gap: 20px;
    border-bottom: 1px solid #00000012;
    padding-block: 15px; 
  }
  .{{ section.id }} .feature-blocks .feature-block:last-child{ border-bottom: none; }
  
  .{{ section.id }} .feature-blocks p, .{{ section.id }} .feature-blocks h3{ text-align: left; }


  @media (max-width:767px){
    .{{ section.id }} .feature-image{ width: 100%; }
    .{{ section.id }} .feature-blocks{ width: 100%;}
     .{{ section.id }} .section-header {
    padding-top: 26px;
}
    .{{ section.id }} .flickity-viewport{ width: 100%; }
    .{{ section.id }} .feature-blocks .feature-block{ 
       border-bottom: 0;
      padding-block: 0;
    }
  }
   {%- assign padding_bottom_mobile = section.settings.padding_bottom_mobile -%}
  {%- if padding_bottom_mobile == 0 -%}
    {%- assign padding_bottom_mobile = section.settings.padding_bottom -%}
  {%- endif -%}

  {%- assign padding_top_mobile = section.settings.padding_top_mobile -%}
  {%- if padding_top_mobile == 0 -%}
    {%- assign padding_top_mobile = section.settings.padding_top -%}
  {%- endif -%}

  .section-{{ section.id }} {
    padding-top: {{ padding_top_mobile }}px;
    padding-bottom: {{ padding_bottom_mobile }}px;
    background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');
    /* You might want to add other background properties like: */
    background-size: cover; /* Or contain, auto, etc. */
    background-repeat: no-repeat; /* Or repeat, repeat-x, repeat-y */
    background-position: center center; /* Or top, bottom, left, right, percentages */
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstyle %}
<section class="media_with_features {{ section.id }} section-{{ section.id }}">
  <!-- <div class="common-shap">
        <img src="https://cdn.shopify.com/s/files/1/0880/4912/3648/files/shap_right.svg?v=1739257435" height="" width="">
      </div> -->
  
  <div class="container page-width">
    <!-- Heading & Description -->
      <div class="section-header text-center">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <div class="description">
            {{ section.settings.description }}
          </div>
        {% endif %}
        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <div class="button_cta">
            <a class="cta_btn btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
          </div>
        {% endif %}
      </div>
    <!-- Main Image -->
    <div class="sec-content">
      {% if section.settings.image != blank or section.settings.video != blank %}
        <div class="feature-image">
          {% if section.settings.video != blank %}
            {{ section.settings.video | video_tag: 
              autoplay: true, 
              loop: true, 
              muted: true, 
              controls: false
            }}
          {% elsif section.settings.image != blank %}
            {%- render 'image-element',
              img: section.settings.image,
              loading: false,
              classes: 'right-image',
              animation: 'none',
            -%}
          {% endif %}
        </div>
      {% endif %}
      
      <!-- Feature Blocks -->
      <div class="feature-blocks ffblocks">

      
      
      {% for block in section.blocks %}
        <div class="feature-block ">
          {% if block.settings.icon != blank %}
            {%- render 'image-element',
              img: block.settings.icon,
              loading: false,
              classes: 'feature-icon',
              animation: 'none',
            -%}
          {% endif %}
          <div class="textWrap">
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}
          
          {% if block.settings.content != blank %}
            <p>{{ block.settings.content }}</p>
          {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    </div>
  </div>
</section>
<script>
                    document.addEventListener("shopify:section:load", function () {
  initializeFlickity1();
});

document.addEventListener("DOMContentLoaded", function () {
  initializeFlickity1();
});

function initializeFlickity1() {
  let carousel = document.querySelector(".ffblocks");
  if (!carousel) return;

  let flickityInstance1 = null;

  function toggleFlickity1() {
    let isMobile = window.innerWidth <= 767;

    if (isMobile && !flickityInstance1) {
      flickityInstance1 = new Flickity(carousel, {
        contain: true,
        cellAlign: "left",
        wrapAround: true,
        autoPlay: 3000,
        prevNextButtons: false,
        adaptiveHeight: true,
        pageDots: true
      });
    } else if (!isMobile && flickityInstance1) {
      flickityInstance1.destroy();
      flickityInstance1 = null;
    }
  }

  toggleFlickity1();
  window.addEventListener("resize", toggleFlickity1);
}

                  </script>

{% schema %}
{
  "name": "Media With Features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },    
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media With Features",
    }
  ]
}
{% endschema %}
