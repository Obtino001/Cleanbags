<style>
wi-cartdrawer {
  width: 100%;
  height: 100dvh;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 10000;
  background-color: rgba(0, 0, 0, 0);
  justify-content: flex-end;
  overflow: hidden;
  display: none;
  transition: 0.3s ease;
}
.WI_cartDrawerin {
  height: 100dvh;
  position: relative;
  display: flex;
  justify-content: flex-start;
  transform: translateX(100%);
  transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
}
.WI_cartDrawerin_cart {
  width: 480px;
  height: 100%;
  background-color: #fff;
  z-index: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}
.WI_cartDrawerin_upsell {
  display: none !important;
}

/* Header Styles */
.WI_cartDrawerin_cart_header {
  width: 100%;
  padding: 24px 24px 16px 24px;
  border-bottom: 1px solid #E7E7E7;
  background-color: #fff;
}
.WI_cartDrawerin_cart_headerH {
  width: 100%;
  margin: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
  font-weight: 500;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 1.5px;
}
.WI_cartDrawerin_cart_header_left {
  display: flex;
  align-items: center;
  gap: 8px;
}
.WI_cartDrawer_bag_icon {
  display: flex;
  align-items: center;
}
.WI_cartDrawer_bag_icon svg {
  width: 18px;
  height: 18px;
}
.WI_cartDrawer_count {
  font-weight: 600;
}
.WI_cartDrawerCls {
  cursor: pointer;
  display: flex;
  align-items: center;
  color: #777;
  transition: color 0.2s;
}
.WI_cartDrawerCls:hover {
  color: #000;
}

/* Free Shipping overrides */
.WI_cartDrawerin_cart_header .fsb-section {
  background-color: transparent !important;
  padding: 12px 0 0 0 !important;
}
.WI_cartDrawerin_cart_header .fsb-container {
  text-align: left !important;
}
.WI_cartDrawerin_cart_header .fsb-text {
  font-size: 13px !important;
  color: #000 !important;
  letter-spacing: 0.5px !important;
  margin: 0 0 8px 0 !important;
  text-transform: none !important;
}
.WI_cartDrawerin_cart_header .fsb-text strong {
  text-transform: uppercase;
  font-weight: 700;
  margin-right: 4px;
  letter-spacing: 1px;
}
.WI_cartDrawerin_cart_header .fsb-money {
  font-weight: 700;
}
.WI_cartDrawerin_cart_header .fsb-progress-track {
  height: 3px !important;
  background-color: #E7E7E7 !important;
  border-radius: 0 !important;
}
.WI_cartDrawerin_cart_header .fsb-progress-fill {
  background-color: #000 !important;
  border-radius: 0 !important;
}

/* Body / Scrolling Container */
.WI_cartDrawerin_cart_body {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-height: 0;
}
.WI_cartDrawerin_cart_body form {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.WI_cartDrawerin_cart_form_in {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  min-height: 0;
  padding: 0 24px 24px 24px;
}
.WI_cartDrawerin_cart_form_in::-webkit-scrollbar {
  width: 4px;
}
.WI_cartDrawerin_cart_form_in::-webkit-scrollbar-thumb {
  background: #E7E7E7;
  border-radius: 4px;
}

.WI_cartDrawerin_cart_empty {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.WI_cartDrawerin_cart_empty_svg {
  text-align: center;
}
.WI_cartDrawerin_cart_empty_svg svg {
  width: 60px;
  height: 60px;
  margin-bottom: 15px;
}
.WI_cartDrawerin_cart_empty_svg p {
  margin: 0;
  font-size: 14px;
  color: #777;
  letter-spacing: 0.5px;
}

/* Items Styles */
.WI_cartDrawerin_cart_items {
  width: 100%;
}
.WI_cartDrawer_item {
  display: flex;
  gap: 16px;
  padding: 24px 0;
  border-bottom: 1px solid #E7E7E7;
  position: relative;
}
.WI_cartDrawer_item_img {
  width: 80px;
  height: 100px;
  flex-shrink: 0;
  background-color: #F9F9F9;
}
.WI_cartDrawer_item_img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.WI_cartDrawer_item_info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.WI_cartDrawer_item_info_top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}
.WI_cartDrawer_item_title {
  font-size: 14px;
  font-weight: 500;
  color: #000;
  text-decoration: none;
  line-height: 1.3;
}
.WI_cartDrawer_item_price {
  font-size: 14px;
  font-weight: 500;
  color: #000;
  text-align: right;
  white-space: nowrap;
}
.WI_cartDrawer_item_price .compare-price {
  text-decoration: line-through;
  color: #888;
  font-size: 12px;
  margin-right: 6px;
}
.WI_cartDrawer_item_options {
  margin-top: 6px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.WI_cartDrawer_item_options .option-tag {
  font-size: 12px;
  color: #777;
}
.WI_cartDrawer_item_info_bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16px;
}

/* Quantity Box */
.WI_cartDrawer_quantity {
  display: flex;
  align-items: center;
  border: 1px solid #E7E7E7;
  width: 84px;
  height: 28px;
}
.WI_cartDrawer_quantity button {
  width: 28px;
  height: 100%;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #000;
  padding: 0;
}
.WI_cartDrawer_quantity button svg {
  width: 10px;
  height: 10px;
  stroke: #000;
}
.WI_cartDrawer_quantity input {
  width: 28px;
  height: 100%;
  border: none;
  text-align: center;
  font-size: 13px;
  color: #000;
  background: transparent;
  padding: 0;
  -moz-appearance: textfield;
}
.WI_cartDrawer_quantity input::-webkit-outer-spin-button,
.WI_cartDrawer_quantity input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* Remove button */
.text-remove-btn {
  background: transparent;
  border: none;
  color: #888;
  font-size: 12px;
  cursor: pointer;
  padding: 0;
  text-decoration: none;
  transition: color 0.2s;
}
.text-remove-btn:hover {
  color: #000;
  text-decoration: underline;
}

/* COMPLETE THE LOOK Scoped Styles */
.WI_complete_look {
  border: 1px solid #E7E7E7;
  margin-top: 24px;
  border-radius: 0;
  overflow: hidden;
}
.WI_complete_look_header {
  background-color: #D6E6F2;
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}
.WI_complete_look_header span {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1.5px;
  color: #000;
}
.WI_complete_look_toggle {
  font-size: 16px;
  font-weight: bold;
  display: flex;
  align-items: center;
  color: #000;
  transition: transform 0.3s;
  user-select: none;
}
.WI_complete_look.open .WI_complete_look_toggle {
  transform: rotate(45deg);
}
.WI_complete_look_body {
  padding: 16px;
  display: none;
  background: #fff;
  border-top: 1px solid #E7E7E7;
}
.WI_complete_look.open .WI_complete_look_body {
  display: block;
}
.WI_complete_look_product {
  display: flex;
  gap: 16px;
}
.WI_complete_look_img {
  width: 70px;
  height: 90px;
  flex-shrink: 0;
  background: #F9F9F9;
}
.WI_complete_look_img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.WI_complete_look_info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.WI_complete_look_info_top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}
.WI_complete_look_title {
  font-size: 13px;
  font-weight: 500;
  color: #000;
  line-height: 1.3;
}
.WI_complete_look_price {
  font-size: 13px;
  font-weight: 600;
  color: #000;
  white-space: nowrap;
}
.WI_complete_look_options {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.WI_complete_look_option_group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.WI_complete_look_option_label {
  font-size: 12px;
  color: #888;
}
.WI_complete_look_option_values {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}
.WI_complete_look_option_val {
  border: 1px solid #E7E7E7;
  background: #fff;
  padding: 5px 12px;
  min-width: 35px;
  text-align: center;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  color: #000;
  transition: all 0.2s;
}
.WI_complete_look_option_val:hover {
  border-color: #000;
}
.WI_complete_look_option_val.selected {
  border-color: #000;
  background: #000;
  color: #fff;
}
.WI_complete_look_add_btn {
  background: #000;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  border: none;
  height: 36px;
  padding: 0 24px;
  cursor: pointer;
  text-transform: uppercase;
  margin-top: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  transition: background 0.2s;
}
.WI_complete_look_add_btn:hover {
  background: #222;
}

/* YOU MAY ALSO LIKE Scoped Styles */
.WI_also_like {
  margin-top: 28px;
  padding-top: 24px;
  border-top: 1px solid #E7E7E7;
}
.WI_also_like_header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.WI_also_like_header span {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1.5px;
  color: #000;
}
.WI_also_like_nav {
  display: flex;
  gap: 6px;
}
.WI_also_like_prev, .WI_also_like_next {
  border: none;
  background: transparent;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  transition: color 0.2s;
}
.WI_also_like_prev:hover, .WI_also_like_next:hover {
  color: #000;
}
.WI_also_like_body {
  width: 100%;
  overflow: hidden;
}
.WI_also_like_list {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  scroll-behavior: smooth;
  -ms-overflow-style: none;
  scrollbar-width: none;
}
.WI_also_like_list::-webkit-scrollbar {
  display: none;
}
.WI_also_like_item {
  flex: 0 0 160px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.WI_also_like_item_img {
  width: 160px;
  height: 180px;
  background-color: #F8F8F8;
  overflow: hidden;
  position: relative;
}
.WI_also_like_item_img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.WI_also_like_item_title {
  font-size: 12px;
  font-weight: 400;
  color: #000;
  text-decoration: none;
  line-height: 1.35;
  margin-top: 2px;
}
.WI_also_like_item_price {
  font-size: 12px;
  color: #777;
}

/* EXERCERE BUNDLE Scoped Styles */
.WI_bundle_promo {
  background-color: #E2ECF5;
  padding: 16px;
  margin-top: 28px;
  border-radius: 0;
}
.WI_bundle_promo_title {
  font-size: 12px;
  font-weight: 700;
  color: #000;
  margin: 0 0 6px 0;
  letter-spacing: 1px;
}
.WI_bundle_promo_desc {
  font-size: 12px;
  color: #333;
  margin: 0;
  line-height: 1.45;
}
.WI_bundle_promo_desc a {
  color: #000;
  text-decoration: underline;
  font-weight: 600;
}

/* Discount Input Scoped Styles */
.WI_discount_wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 24px;
  padding-bottom: 24px;
}
.WI_discount_input {
  flex: 1;
  border: none;
  border-bottom: 1.5px solid #ccc;
  padding: 8px 0;
  font-size: 13px;
  outline: none;
  background: transparent;
  color: #000;
  transition: border-color 0.2s;
}
.WI_discount_input:focus {
  border-color: #000;
}
.WI_discount_btn {
  border: 1px solid #E7E7E7;
  background: #fff;
  color: #000;
  padding: 8px 16px;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  letter-spacing: 1px;
  transition: all 0.2s;
}
.WI_discount_btn:hover {
  border-color: #000;
  background: #F9F9F9;
}

/* Loader indicators during ajax fetch */
.WI_cartLoading {
  width: 100%;
  height: 2px;
  position: absolute;
  bottom: 0;
  overflow: hidden;
}
.WI_cartLoadingin {
  width: 100%;
  height: 2px;
  background-color: #f2f2f2;
  position: relative;
  display: none;
}
.WI_cartLoadingActive {
  display: block;
}
.WI_cartLoadingActive:before {
  content: "";
  position: absolute;
  top: 0;
  left: -50%;
  height: 2px;
  width: 40%;
  background-color: #000;
  animation: lineAnim 1s linear infinite;
}
@keyframes lineAnim {
  0% { left: -40%; }
  50% { left: 20%; width: 80%; }
  100% { left: 100%; width: 100%; }
}

/* Footer Styles */
.WI_cartDrawerin_cart_footer {
  width: 100%;
  padding: 16px 24px;
  border-top: 1px solid #E7E7E7;
  background-color: #fff;
  z-index: 10;
  flex-shrink: 0;
}
.WI_cartDrawer_total {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.WI_cartDrawer_total h5 {
  margin: 0;
  font-size: 13px;
  color: #000;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.WI_cartDrawer_total h5.WI_cartDrawer_total_price {
  font-size: 16px;
  font-weight: 700;
}
.WI_cartDrawer_checkout {
  width: 100%;
  height: 48px;
  background-color: #000 !important;
  color: #fff !important;
  border: none;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.2s;
}
.WI_cartDrawer_checkout:hover {
  background-color: #222 !important;
}

/* Custom Badges row styling */
.WI_cartDrawer_badges {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  padding: 0;
  list-style: none;
}
.WI_cartDrawer_badges li {
  display: flex;
  align-items: center;
}
.WI_cartDrawer_badges svg, .WI_cartDrawer_badges img {
  height: 20px;
  width: 32px;
  object-fit: contain;
}
.WI_cartDrawer_subtext {
  font-size: 11px;
  color: #777;
  text-align: center;
  margin: 0;
  line-height: 1.4;
}

@media screen and (max-width: 800px) {
  .WI_cartDrawerin_cart {
    width: calc(100vw - 30px);
    height: 100dvh;
  }
  .WI_cartDrawerin_cart_footer {
    padding-bottom: max(16px, env(safe-area-inset-bottom));
  }
}

/* Staggered slide-in from left to right when active */
wi-cartdrawer .WI_cartDrawerin_cart_header,
wi-cartdrawer .WI_cartDrawer_item,
wi-cartdrawer .WI_complete_look,
wi-cartdrawer .WI_also_like,
wi-cartdrawer .WI_bundle_promo,
wi-cartdrawer .WI_discount_wrap,
wi-cartdrawer .WI_cartDrawerin_cart_footer {
  opacity: 0;
  transform: translateX(-40px);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
}

wi-cartdrawer.active .WI_cartDrawerin_cart_header,
wi-cartdrawer.active .WI_cartDrawer_item,
wi-cartdrawer.active .WI_complete_look,
wi-cartdrawer.active .WI_also_like,
wi-cartdrawer.active .WI_bundle_promo,
wi-cartdrawer.active .WI_discount_wrap,
wi-cartdrawer.active .WI_cartDrawerin_cart_footer {
  opacity: 1;
  transform: translateX(0);
}

/* Staggered transition delays */
wi-cartdrawer.active .WI_cartDrawerin_cart_header {
  transition-delay: 0.1s;
}
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(1) {
  transition-delay: 0.15s;
}
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(2) {
  transition-delay: 0.2s;
}
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(3) {
  transition-delay: 0.25s;
}
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(4) {
  transition-delay: 0.3s;
}
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(n+5) {
  transition-delay: 0.35s;
}
wi-cartdrawer.active .WI_complete_look {
  transition-delay: 0.35s;
}
wi-cartdrawer.active .WI_also_like {
  transition-delay: 0.4s;
}
wi-cartdrawer.active .WI_bundle_promo {
  transition-delay: 0.45s;
}
wi-cartdrawer.active .WI_discount_wrap {
  transition-delay: 0.5s;
}
wi-cartdrawer.active .WI_cartDrawerin_cart_footer {
  transition-delay: 0.25s;
}

wi-cartdrawer:not(.active) .WI_cartDrawerin_cart_header,
wi-cartdrawer:not(.active) .WI_cartDrawer_item,
wi-cartdrawer:not(.active) .WI_complete_look,
wi-cartdrawer:not(.active) .WI_also_like,
wi-cartdrawer:not(.active) .WI_bundle_promo,
wi-cartdrawer:not(.active) .WI_discount_wrap,
wi-cartdrawer:not(.active) .WI_cartDrawerin_cart_footer {
  transition: none !important;
}
</style>
<wi-cartdrawer>
    <div class="WI_cartDrawerin">
        <div class="WI_cartDrawerin_cart">
            <data-cart-count hidden>{{ cart.item_count }}</data-cart-count>
            <div class="WI_cartDrawerin_cart_header">
                <h2 class="WI_cartDrawerin_cart_headerH">
                  <div class="WI_cartDrawerin_cart_header_left">
                    <span class="WI_cartDrawer_bag_icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="19" height="20" viewBox="0 0 19 20" fill="none">
                        <mask id="mask0_288_159" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="1" y="1" width="17" height="17">
                          <path d="M17.2464 1.65829H1.32682V17.5779H17.2464V1.65829Z" fill="white"/>
                        </mask>
                        <g mask="url(#mask0_288_159)">
                          <path d="M14.5931 5.37195H3.98002V16.4493H14.5931V5.37195Z" stroke="#000" stroke-width="1.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M7.62828 7.03128V3.64837C7.62828 3.18405 8.02627 2.78606 8.49059 2.78606H10.2152C10.6795 2.78606 11.0775 3.18405 11.0775 3.64837V7.09761" stroke="#000" stroke-width="1.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                      </svg>
                    </span>
                    <span class="WI_cartDrawer_count">{{ 'cart.general.title' | t | upcase }} ({{ cart.item_count }})</span>
                  </div>
                  <span class="WI_cartDrawerCls">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                </h2>
                {% render 'free-shipping' %}
            </div>
            <div class="WI_loadingCartItemBlock">
              <div class="WI_loadingCartItemBlock_in">
                <div class="WI_cartLoading_eBox">
                  <div class="WI_cartLoadingin_eBox WI_cartLoadingActive_eBox"></div>
                </div>
              </div>
            </div>
            
            {% if cart.item_count > 0 %}
            <div class="WI_cartDrawerin_cart_body">
                {% form 'cart', cart %}
                <div class="WI_cartDrawerin_cart_form_in">
                    <div class="WI_cartDrawerin_cart_items">
                        {% for item in cart.items %}
                        <div class="WI_cartDrawer_item" data-itemKey="{{item.key}}" 
                        data-savingPrice="{%- if item.variant.compare_at_price -%}{{ item.variant.compare_at_price | minus: item.variant.price | times: item.quantity }}{%- endif -%}">
                            <div class="WI_cartDrawer_item_img">
                                <a href="{{ item.product.url }}">{{item.image | image_url: width: 250 | image_tag: loading: 'eager'}}</a>
                            </div>
                            <div class="WI_cartDrawer_item_info">
                                <div class="WI_cartDrawer_item_info_top">
                                    <a href="{{ item.product.url }}" class="WI_cartDrawer_item_title">{{item.product.title | escape}}</a>
                                    <span class="WI_cartDrawer_item_price">
                                        {%- if item.variant.compare_at_price > item.variant.price -%}
                                        <span class="compare-price">{{item.variant.compare_at_price | money}}</span>
                                        <span>{{item.variant.price | money}}</span>
                                        {%- else -%}
                                        <span>{{item.variant.price | money}}</span>
                                        {%- endif -%}
                                    </span>
                                </div>
                                
                                {%- if item.product.has_only_default_variant == false or item.properties.size > 0 -%}
                                    <div class="WI_cartDrawer_item_options">
                                        {%- if item.product.has_only_default_variant == false -%}
                                            {%- for option in item.options_with_values -%}
                                                <span class="option-tag">{{ option.name }}: {{ option.value }}</span>
                                            {%- endfor -%}
                                        {%- endif -%}
                                        {%- assign property_size = item.properties | size -%}
                                        {%- if property_size > 0 -%}
                                            {%- for p in item.properties -%}
                                                {%- assign first_character_in_key = p.first | truncate: 1, '' -%}
                                                {%- unless p.last == blank or first_character_in_key == '_' -%}
                                                    <span class="option-tag">
                                                        <strong>{{ p.first }}:</strong>
                                                         {%- if p.last contains '/uploads/' -%}
                                                             <a href="{{ p.last }}" target="_blank">{{ p.last | split: '/' | last }}</a>
                                                        {%- else -%}
                                                            {{ p.last }}
                                                        {%- endif -%}
                                                    </span>
                                                {%- endunless -%}
                                            {%- endfor -%}
                                        {%- endif -%}
                                    </div>
                                {%- endif -%}
                                
                                <div class="WI_cartDrawer_item_info_bottom">
                                    <div class="WI_cartDrawer_quantity">
                                        <button type="button" class="WI_cartDrawer_minus">
                                          <svg class="WI_cartDrawer_minus" width="10" height="2" viewBox="0 0 10 2" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path class="WI_cartDrawer_minus" d="M0 1H10" stroke="currentColor" stroke-width="1.5"/>
                                          </svg>
                                        </button>
                                        <input value="{{ item.quantity }}" type="number" readonly />
                                        <button type="button" class="WI_cartDrawer_plus">
                                          <svg class="WI_cartDrawer_plus" width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path class="WI_cartDrawer_plus" d="M5 0V10M0 5H10" stroke="currentColor" stroke-width="1.5"/>
                                          </svg>
                                        </button>
                                    </div>
                                     <button type="button" class="cartDrawerRemove text-remove-btn">{{ 'cart.general.remove' | t }}</button>
                                </div>
                            </div>
                            <div class="WI_cartLoading">
                                <div class="WI_cartLoadingin"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    {% comment %} Dynamic Recommendations logic for Complete the Look & You May Also Like {% endcomment %}
                    {% assign exclusion_list = "" %}
                    {% for item in cart.items %}
                      {% assign exclusion_list = exclusion_list | append: item.product.handle | append: "," %}
                    {% endfor %}

                    {% assign recommended_products = "" %}
                    {% for item in cart.items %}
                      {% for col in item.product.collections %}
                        {% unless col.handle == 'all' or col.handle == 'frontpage' %}
                          {% for prod in col.products %}
                            {% unless exclusion_list contains prod.handle %}
                              {% if prod.available %}
                                {% assign recommended_products = recommended_products | append: prod.handle | append: "," %}
                                {% assign exclusion_list = exclusion_list | append: prod.handle | append: "," %}
                              {% endif %}
                            {% endunless %}
                          {% endfor %}
                        {% endunless %}
                      {% endfor %}
                    {% endfor %}

                    {% comment %} Fallback to filling recommendations with general catalog products if needed {% endcomment %}
                    {% assign rec_array = recommended_products | split: "," %}
                    {% if rec_array.size < 6 %}
                      {% for prod in collections['all'].products %}
                        {% unless exclusion_list contains prod.handle %}
                          {% if prod.available %}
                            {% assign recommended_products = recommended_products | append: prod.handle | append: "," %}
                            {% assign exclusion_list = exclusion_list | append: prod.handle | append: "," %}
                          {% endif %}
                        {% endunless %}
                        {% assign temp_array = recommended_products | split: "," %}
                        {% if temp_array.size >= 7 %}{% break %}{% endif %}
                      {% endfor %}
                    {% endif %}

                    {% assign rec_handles = recommended_products | split: "," %}
                    
                    {% comment %} COMPLETE THE LOOK (Product 1) {% endcomment %}
                    {% if rec_handles.size > 0 %}
                      {% assign first_rec_handle = rec_handles[0] %}
                      {% assign first_product = all_products[first_rec_handle] %}
                      {% if first_product.handle != blank %}
                        <div class="WI_complete_look open">
                          <div class="WI_complete_look_header" onclick="this.closest('.WI_complete_look').classList.toggle('open')">
                            <span>{{ section.settings.complete_look_title | default: 'COMPLETE THE LOOK' }}</span>
                            <span class="WI_complete_look_toggle"><svg xmlns="http://www.w3.org/2000/svg" class="icon-cancel" width="9" height="9" viewBox="0 0 9 9" fill="none">
    <path d="M0.5 8.5L4.5 4.5L0.5 8.5ZM8.5 0.5L4.49924 4.5L8.5 0.5ZM4.49924 4.5L0.5 0.5L4.49924 4.5ZM4.5 4.5L8.5 8.5L4.5 4.5Z" fill="#0B0B0B"></path>
    <path d="M0.5 8.5L4.5 4.5L8.5 8.5M8.5 0.5L4.49924 4.5L0.5 0.5" stroke="#0B0B0B" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></span>
                          </div>
                          <div class="WI_complete_look_body">
                            <div class="WI_complete_look_product">
                              <div class="WI_complete_look_img">
                                <img src="{{ first_product.featured_image | image_url: width: 150 }}" alt="{{ first_product.title | escape }}">
                              </div>
                              <div class="WI_complete_look_info">
                                <div class="WI_complete_look_info_top">
                                  <span class="WI_complete_look_title">{{ first_product.title }}</span>
                                  <span class="WI_complete_look_price">{{ first_product.price | money }}</span>
                                </div>
                                
                                <div class="WI_complete_look_options">
                                  {%- unless first_product.has_only_default_variant -%}
                                    {%- for option in first_product.options_with_values -%}
                                      <div class="WI_complete_look_option_group">
                                        <span class="WI_complete_look_option_label">{{ option.name }}:</span>
                                        <div class="WI_complete_look_option_values">
                                          {%- for value in option.values -%}
                                            <button type="button" class="WI_complete_look_option_val {% if forloop.first %}selected{% endif %}" data-value="{{ value | escape }}">{{ value }}</button>
                                          {%- endfor -%}
                                        </div>
                                      </div>
                                    {%- endfor -%}
                                  {%- endunless -%}
                                </div>

                                <div class="WI_complete_look_form">
                                  {% if first_product.variants.size == 1 %}
                                    <input type="hidden" name="id" value="{{ first_product.variants[0].id }}">
                                  {% else %}
                                    <input type="hidden" name="id" class="WI_complete_look_variant_id" value="{{ first_product.variants[0].id }}">
                                    <select name="id" class="WI_complete_look_variant_select" style="display:none;">
                                      {% for variant in first_product.variants %}
                                        <option value="{{ variant.id }}" data-options="{{ variant.options | join: ',' }}">{{ variant.title }}</option>
                                      {% endfor %}
                                    </select>
                                  {% endif %}
                                  <button type="button" class="WI_complete_look_add_btn">{{ section.settings.complete_look_add_btn_text | default: '+ ADD' }}</button>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      {% endif %}
                    {% endif %}

                    {% comment %} YOU MAY ALSO LIKE (Products 2+) {% endcomment %}
                    {% if rec_handles.size > 1 %}
                      <div class="WI_also_like">
                        <div class="WI_also_like_header">
                          <span>{{ section.settings.you_may_also_like_title | default: 'YOU MAY ALSO LIKE' }}</span>
                          <div class="WI_also_like_nav">
                            <button type="button" class="WI_also_like_prev">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="15 18 9 12 15 6"></polyline>
                              </svg>
                            </button>
                            <button type="button" class="WI_also_like_next">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"></polyline>
                              </svg>
                            </button>
                          </div>
                        </div>
                        <div class="WI_also_like_body">
                          <div class="WI_also_like_list">
                            {% for handle in rec_handles offset: 1 limit: 6 %}
                              {% assign prod = all_products[handle] %}
                              {% if prod.handle != blank %}
                                <div class="WI_also_like_item">
                                  <div class="WI_also_like_item_img">
                                    <a href="{{ prod.url }}">
                                      <img src="{{ prod.featured_image | image_url: width: 250 }}" alt="{{ prod.title | escape }}">
                                    </a>
                                  </div>
                                  <a href="{{ prod.url }}" class="WI_also_like_item_title">{{ prod.title }}</a>
                                  <span class="WI_also_like_item_price">{{ prod.price | money }}</span>
                                </div>
                              {% endif %}
                            {% endfor %}
                          </div>
                        </div>
                      </div>
                    {% endif %}

                    {% comment %} EXERCERE BUNDLE promo box {% endcomment %}
                    <div class="WI_bundle_promo">
                      <h4 class="WI_bundle_promo_title">{{ section.settings.bundle_title }}</h4>
                      <div class="WI_bundle_promo_desc">
                        {{ section.settings.bundle_desc }}
                      </div>
                    </div>

                    {% comment %} Discount Code Input {% endcomment %}
                    <div class="WI_discount_wrap">
                      <input type="text" name="discount" class="WI_discount_input" placeholder="{{ section.settings.discount_placeholder | default: 'Enter discount code' }}" autocomplete="off">
                      <button type="button" class="WI_discount_btn" data-applied-text="{{ section.settings.discount_applied_btn_text | default: 'APPLIED' }}">{{ section.settings.discount_btn_text | default: 'APPLY' }}</button>
                    </div>

                </div>
                
                <div class="WI_cartDrawerin_cart_footer">
                    <div class="WI_cartDrawer_total">
                        <h5>{{ 'cart.general.subtotal' | t }}</h5>
                        <h5 class="WI_cartDrawer_total_price">{{ cart.total_price | money }}</h5>
                    </div>

                    <button type="submit" name="checkout" value="Checkout" class="WI_cartDrawer_checkout">{{ section.settings.checkout_btn_text | default: 'GO TO CHECKOUT' }}</button>
                    
                    <ul class="WI_cartDrawer_badges">
                      <!-- Apple Pay -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24">
                          <rect width="38" height="24" rx="2" fill="#000"/>
                          <path fill="#fff" d="M15.4 12.3c.7-1 1.2-2.3 1.1-3.6-1.1.1-2.5.8-3.3 1.7-.7.8-1.3 2.2-1.1 3.5 1.2.1 2.5-.6 3.3-1.6zm.9 1.8c-1.8-.1-3.3.9-4.2.9-.9 0-2.2-1-3.6-1-1.8 0-3.5 1-4.4 2.7-1.9 3.3-.5 8.2 1.3 10.9.9 1.3 2 2.8 3.5 2.7 1.4-.1 1.9-1 3.6-1 1.7 0 2.1 1 3.6 1 1.5 0 2.5-1.4 3.4-2.7 1-1.5 1.5-3 1.5-3.1 0 0-2.9-1.1-2.9-4.4 0-2.8 2.3-4.1 2.3-4.1-1.3-1.9-3.3-2.1-4-2.2z" transform="scale(0.85) translate(4, 2)"/>
                        </svg>
                      </li>
                      <!-- Visa -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24">
                          <rect width="38" height="24" rx="2" fill="#fff" stroke="#e0e0e0" stroke-width="1"/>
                          <path d="M28.3 10.1H28c-.4 1-.7 1.5-1 3h1.9c-.3-1.5-.3-2.2-.6-3zm2.9 5.9h-1.7c-.1 0-.1 0-.2-.1l-.2-.9-.1-.2h-2.4c-.1 0-.2 0-.2.2l-.3.9c0 .1-.1.1-.1.1h-2.1l.2-.5L27 8.7c0-.5.3-.7.8-.7h1.5c.1 0 .2 0 .2.2l1.4 6.5c.1.4.2.7.2 1.1.1.1.1.1.1.2zm-13.4-.3l.4-1.8c.1 0 .2.1.2.1.7.3 1.4.5 2.1.4.2 0 .5-.1.7-.2.5-.2.5-.7.1-1.1-.2-.2-.5-.3-.8-.5-.4-.2-.8-.4-1.1-.7-1.2-1-.8-2.4-.1-3.1.6-.4.9-.8 1.7-.8 1.2 0 2.5 0 3.1.2h.1c-.1.6-.2 1.1-.4 1.7-.5-.2-1-.4-1.5-.4-.3 0-.6 0-.9.1-.2 0-.3.1-.4.2-.2.2-.2.5 0 .7l.5.4c.4.2.8.4 1.1.6.5.3 1 .8 1.1 1.4.2.9-.1 1.7-.9 2.3-.5.4-.7.6-1.4.6-1.4 0-2.5.1-3.4-.2-.1.2-.1.2-.2.1zm-3.5.3c.1-.7.1-.7.2-1 .5-2.2 1-4.5 1.4-6.7.1-.2.1-.3.3-.3H18c-.2 1.2-.4 2.1-.7 3.2-.3 1.5-.6 3-1 4.5 0 .2-.1.2-.3.2M5 8.2c0-.1.2-.2.3-.2h3.4c.5 0 .9.3 1 .8l.9 4.4c0 .1 0 .1.1.2 0-.1.1-.1.1-.1l2.1-5.1c-.1-.1 0-.2.1-.2h2.1c0 .1 0 .1-.1.2l-3.1 7.3c-.1.2-.1.3-.2.4-.1.1-.3 0-.5 0H9.7c-.1 0-.2 0-.2-.2L7.9 9.5c-.2-.2-.5-.5-.9-.6-.6-.3-1.7-.5-1.9-.5L5 8.2z" fill="#142688"/>
                        </svg>
                      </li>
                      <!-- Mastercard -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24">
                          <rect width="38" height="24" rx="2" fill="#fff" stroke="#e0e0e0" stroke-width="1"/>
                          <circle fill="#EB001B" cx="15" cy="12" r="7"/>
                          <circle fill="#F79E1B" cx="23" cy="12" r="7"/>
                          <path fill="#FF5F00" d="M22 12c0-2.4-1.2-4.5-3-5.7-1.8 1.3-3 3.4-3 5.7s1.2 4.5 3 5.7c1.8-1.2 3-3.3 3-5.7z"/>
                        </svg>
                      </li>
                      <!-- PayPal -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24">
                          <rect width="38" height="24" rx="2" fill="#fff" stroke="#e0e0e0" stroke-width="1"/>
                          <path fill="#003087" d="M23.9 8.3c.2-1 0-1.7-.6-2.3-.6-.7-1.7-1-3.1-1h-4.1c-.3 0-.5.2-.6.5L14 15.6c0 .2.1.4.3.4H17l.4-3.4 1.8-2.2 4.7-2.1z"/>
                          <path fill="#3086C8" d="M23.9 8.3l-.2.2c-.5 2.8-2.2 3.8-4.6 3.8H18c-.3 0-.5.2-.6.5l-.6 3.9-.2 1c0 .2.1.4.3.4H19c.3 0 .5-.2.5-.4v-.1l.4-2.4v-.1c0-.2.3-.4.5-.4h.3c2.1 0 3.7-.8 4.1-3.2.2-1 .1-1.8-.4-2.4-.1-.5-.3-.7-.5-.8z"/>
                          <path fill="#012169" d="M23.3 8.1c-.1-.1-.2-.1-.3-.1-.1 0-.2 0-.3-.1-.3-.1-.7-.1-1.1-.1h-3c-.1 0-.2 0-.2.1-.2.1-.3.2-.3.4l-.7 4.4v.1c0-.3.3-.5.6-.5h1.3c2.5 0 4.1-1 4.6-3.8v-.2c-.1-.1-.3-.2-.5-.2h-.1z"/>
                        </svg>
                      </li>
                      <!-- Klarna -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24" fill="none">
                          <rect width="38" height="24" rx="2" fill="#FFA8CD"/>
                          <path d="M30.62 14.755c-.662 0-1.179-.554-1.179-1.226 0-.673.517-1.226 1.18-1.226.663 0 1.18.553 1.18 1.226 0 .672-.517 1.226-1.18 1.226zm-.33 1.295c.565 0 1.286-.217 1.686-1.068l.04.02c-.176.465-.176.742-.176.81v.11h1.423v-4.786H31.84v.109c0 .069 0 .346.175.81l-.039.02c-.4-.85-1.121-1.068-1.687-1.068-1.355 0-2.31 1.088-2.31 2.522 0 1.433.955 2.521 2.31 2.521zm-4.788-5.043c-.643 0-1.15.228-1.56 1.068l-.039-.02c.175-.464.175-.741.175-.81v-.11h-1.423v4.787h1.462V13.4c0-.662.38-1.078.995-1.078.614 0 .917.356.917 1.068v2.532h1.462v-3.046c0-1.088-.838-1.869-1.989-1.869zm-4.963 1.068l-.039-.02c.176-.464.176-.741.176-.81v-.11h-1.424v4.787h1.463l.01-2.304c0-.673.35-1.078.926-1.078.156 0 .282.02.429.06v-1.464c-.644-.139-1.22.109-1.54.94zm-4.65 2.68c-.664 0-1.18-.554-1.18-1.226 0-.673.516-1.226 1.18-1.226.662 0 1.179.553 1.179 1.226 0 .672-.517 1.226-1.18 1.226zm-.332 1.295c.565 0 1.287-.217 1.687-1.068l.038.02c-.175.465-.175.742-.175.81v.11h1.424v-4.786h-1.424v.109c0 .069 0 .346.175.81l-.038.02c-.4-.85-1.122-1.068-1.687-1.068-1.356 0-2.311 1.088-2.311 2.522 0 1.433.955 2.521 2.31 2.521zm-4.349-.128h1.463V9h-1.463v6.922zM10.136 9H8.644c0 1.236-.751 2.343-1.892 3.134l-.448.317V9h-1.55v6.922h1.55V12.49l2.564 3.43h1.892L8.293 12.64c1.121-.82 1.852-2.096 1.843-3.639z" fill="#0B051D"/>
                        </svg>
                      </li>
                      <!-- UPS -->
                      <li>
                        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24">
                          <rect width="38" height="24" rx="2" fill="#351C15" stroke="#4E2B1F" stroke-width="1"/>
                          <path d="M19 4.5c-4.5 0-5.5 3-5.5 5.5v3.5c0 4.5 3.5 6.5 5.5 6.5s5.5-2 5.5-6.5v-3.5c0-2.5-1-5.5-5.5-5.5zm-2.5 5.2h1.2v3.7c0 1.5.8 2.2 1.8 2.2s1.8-.7 1.8-2.2v-3.7h1.2v3.7c0 2.2-1.2 3.2-3 3.2s-3-1-3-3.2v-3.7z" fill="#FFC72C"/>
                          <path d="M11 6v4c0 6 8 9.5 8 9.5s8-3.5 8-9.5V6c-4 0-8-1.5-8-1.5S15 6 11 6z" fill="none" stroke="#FFC72C" stroke-width="1"/>
                        </svg>
                      </li>
                    </ul>
                    <p class="WI_cartDrawer_subtext">
                      {{ 'cart.general.shipping_at_checkout' | t }}
                    </p>
                </div>
                {% endform %}
            </div>
            {%- else -%}
              <div class="WI_cartDrawerin_cart_empty">
                <div class="WI_cartDrawerin_cart_empty_svg">
                  <svg width="56" viewBox="0 0 65 74" xmlns="http://www.w3.org/2000/svg"><g fill-rule="nonzero" fill="none"><path d="M64.407 9.856L53.605 0H11.371L.569 9.856A1.548 1.548 0 00.1 11.603c.235.619.843 1.031 1.524 1.031h61.727a1.62 1.62 0 001.522-1.031 1.545 1.545 0 00-.467-1.747z" fill="#C4C4C4"></path><path d="M63.351 9.927H1.624C.728 9.927 0 10.644 0 11.529v59.267C0 72.566 1.454 74 3.249 74h58.478c1.795 0 3.249-1.434 3.249-3.204V11.53c0-.885-.728-1.602-1.625-1.602z" fill="#E4E4E4"></path><path d="M32.488 45.122c-7.963 0-14.44-6.447-14.44-14.37v-4.79a1.6 1.6 0 011.605-1.596 1.6 1.6 0 011.604 1.596v4.79c0 6.163 5.04 11.177 11.23 11.177 6.192 0 11.231-5.014 11.231-11.177v-4.79a1.6 1.6 0 011.604-1.596 1.6 1.6 0 011.605 1.596v4.79c0 7.923-6.477 14.37-14.44 14.37z" fill="#6D6D6D"></path></g></svg>
                  <p>{{ 'general.cart.empty' | t }}</p>
                </div>
              </div>
            {% endif %}
        </div>
    </div>
</wi-cartdrawer>


{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "text",
      "id": "complete_look_title",
      "label": "Complete the Look Title",
      "default": "COMPLETE THE LOOK"
    },
    {
      "type": "text",
      "id": "complete_look_add_btn_text",
      "label": "Complete the Look Add Button Text",
      "default": "+ ADD"
    },
    {
      "type": "text",
      "id": "you_may_also_like_title",
      "label": "You May Also Like Title",
      "default": "YOU MAY ALSO LIKE"
    },
    {
      "type": "text",
      "id": "bundle_title",
      "label": "Bundle Title",
      "default": "EXERCERE BUNDLE"
    },
    {
      "type": "richtext",
      "id": "bundle_desc",
      "label": "Bundle Description",
      "default": "<p>Save 15% off when buying a bundle. Simply add a <a href=\"/collections/tops\">Top</a>, <a href=\"/collections/blouses\">Blouse</a> and <a href=\"/collections/bottoms\">Bottom</a> to your cart. Already discounted items are excluded.</p>"
