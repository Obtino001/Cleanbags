{% endschema %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const videoCovers = document.querySelectorAll('.video-cover');
    const closeButtons = document.querySelectorAll('.close-popup');
  
    videoCovers.forEach(cover => {
      cover.addEventListener('click', function() {
        const videoId = this.dataset.videoId;
        const popup = document.getElementById(`video-popup-${videoId}`);
        if (popup) {
          popup.classList.add('open');
        }
      });
    });
  
    closeButtons.forEach(button => {
      button.addEventListener('click', function() {
        const popup = this.closest('.video-popup');
        if (popup) {
          popup.classList.remove('open');
          // Optional: Pause the video when closing
          const video = popup.querySelector('.popup-video');
          if (video) {
            video.pause();
          }
        }
      });
    });
  
    const reviewSlider = document.querySelector('.review-slider');
    if (reviewSlider) {
      new Flickity(reviewSlider, {
        cellAlign: 'left',
        contain: true,
        wrapAround: true,
        groupCells: 4,
        pageDots: true,
        prevNextButtons: true
      });
    }
  });

    window.addEventListener('load', function () {
    const slider = document.querySelector('.review-slider');
    if (!slider) return;

    // Wait for all images inside the slider to load
    const images = slider.querySelectorAll('img');
    let loaded = 0;

    images.forEach(img => {
      if (img.complete) {
        loaded++;
      } else {
        img.addEventListener('load', () => {
          loaded++;
          if (loaded === images.length) {
            initializeFlickity();
          }
        });
        img.addEventListener('error', () => loaded++);
      }
    });

    if (loaded === images.length) {
      initializeFlickity();
    }

    function initializeFlickity() {
      const flkty = new Flickity(slider, {
        cellAlign: 'left',
        contain: true,
        wrapAround: true,
        groupCells: 1,
        pageDots: true,
        prevNextButtons: true,
        imagesLoaded: true
      });

      // Force height recalc
      flkty.resize();
    }
  });



{% endjavascript %}

{% style %}
  .video-container {
    position: relative;
  }
  
  .video-cover {
    position: relative;
    cursor: pointer;
  }
  
  .cover-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px; /* Optional: match image border-radius */
  }
  
  .play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2em; /* Adjust size */
    color: white;
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 50%;
    width: 50px; /* Adjust size */
    height: 50px; /* Adjust size */
    line-height: 50px;
    text-align: center;
    opacity: 0.8;
  }
  
  .video-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease-in-out;
  }
  
  .video-popup.open {
    opacity: 1;
    visibility: visible;
  }
  
  .video-popup-inner {
    position: relative;
    background-color: white;
    border-radius: 10px;
    max-width: 80%; /* Adjust as needed */
    max-height: 80%; /* Adjust as needed */
  }
  
  .popup-video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
  }
  
  .close-popup {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 2em;
    color: black;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 1001;
  }
  .video-popup {
  position: fixed; /* Crucial for covering the viewport */
  top: 0;
  left: 0;
  width: 100%; /* Covers the entire viewport width */
  height: 100%; /* Covers the entire viewport height */
  background-color: rgba(0, 0, 0, 0.8); /* Semi-transparent background */
  display: flex; /* For centering the content */
  justify-content: center; /* Center horizontally */
  align-items: center; /* Center vertically */
  z-index: 1000; /* Ensure it's on top of other content */
  opacity: 0; /* Initially hidden */
  visibility: hidden; /* Initially hidden */
  transition: opacity 0.3s ease-in-out; /* Smooth fade-in/out */
}

.video-popup.open {
  opacity: 1; /* Make it visible when the 'open' class is added */
  visibility: visible;
}

.video-popup-inner {
  position: relative; /* For positioning the close button */
  background-color: white;
  border-radius: 10px;
  width: 90%; /* Adjust as needed (relative to viewport) */
  height: 90%; /* Adjust as needed (relative to viewport) */
  max-width: none; /* Override any potential max-width */
  max-height: none; /* Override any potential max-height */
}

.popup-video {
  width: 100%; /* Fill the inner container width */
  height: 100%; /* Fill the inner container height */
  display: block;
  border-radius: 10px;
  object-fit: contain; /* Or 'cover' depending on desired behavior */
}

.close-popup {
  position: absolute;
  top: 20px; /* Adjust position as needed */
  right: 20px; /* Adjust position as needed */
  font-size: 2em;
  color: black;
  background: none;
  border: none;
  cursor: pointer;
  z-index: 1001; /* Ensure it's above the video */
}

  .video-popup-inner {
  position: relative;
  background-color: white;
  border-radius: 10px;
  width: 95%; /* Adjust as needed (percentage of viewport width) */
  height: 90%; /* Adjust as needed (percentage of viewport height) */
  max-width: none; /* Ensure it can expand beyond default max-width */
  max-height: none; /* Ensure it can expand beyond default max-height */
}

.popup-video {
  width: 100%; /* Make it fill the width of .video-popup-inner */
  height: 100%; /* Make it fill the height of .video-popup-inner */
  display: block;
  border-radius: 10px;
  object-fit: contain; /* Or 'cover' depending on how you want scaling */
}
{% endstyle %}